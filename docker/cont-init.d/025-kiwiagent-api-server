#!/command/with-contenv sh
# shellcheck shell=sh
#
# kiwiagent SaaS 场景专用: 从环境变量把 hermes 的 config.yaml 补上两块 SaaS
# 必需字段, 而 hermes 上游本身不做 YAML 里的 ${VAR} env 展开:
#   1. platforms.api_server.{enabled, extra.key}   —— 让 gateway 能调 pod
#   2. model.{provider, base_url, api_key, default} —— 让 hermes 把推理走
#      集群内的 LiteLLM 而不是默认的 OpenRouter
#
# 序号 025: 在 stage2 (01-hermes-setup seed) 和 02-reconcile-profiles 之后,
# 保证 config.yaml 已 seed 出来才做 patch. 幂等: 同 key/base_url 已经写入
# 就 no-op.
#
# 触发条件:
#   API_SERVER_KEY   -> 开 api_server (SaaS gateway 契约)
#   LITELLM_BASE_URL -> 把 model provider 指向 LiteLLM
# 都不设时脚本静默退出, 对 non-kiwiagent 场景零影响.
set -eu

HERMES_HOME="${HERMES_HOME:-/opt/data}"
CFG="$HERMES_HOME/config.yaml"

# 两个触发条件都没设 → 不是 SaaS pod, 立即返回
if [ -z "${API_SERVER_KEY:-}" ] && [ -z "${LITELLM_BASE_URL:-}" ]; then
    exit 0
fi

# config.yaml 一定要在 —— 依赖 01-hermes-setup 的 seed 逻辑
if [ ! -f "$CFG" ]; then
    echo "[025-kiwiagent] $CFG missing (seed 未运行?), 跳过" >&2
    exit 0
fi

exec s6-setuidgid hermes /opt/hermes/.venv/bin/python - <<'PY'
import os, sys, yaml, pathlib

cfg_path = pathlib.Path(os.environ.get("HERMES_HOME", "/opt/data")) / "config.yaml"
data = yaml.safe_load(cfg_path.read_text()) or {}
dirty = False

# ---------- 1) API server (gateway 调 pod 用) ----------
api_key = os.environ.get("API_SERVER_KEY")
if api_key:
    platforms = data.setdefault("platforms", {})
    api_server = platforms.setdefault("api_server", {})
    extra = api_server.setdefault("extra", {})
    if not (api_server.get("enabled") is True and extra.get("key") == api_key):
        api_server["enabled"] = True
        extra["key"] = api_key
        host = os.environ.get("API_SERVER_HOST")
        if host:
            extra.setdefault("host", host)
        dirty = True

# ---------- 2) LiteLLM 作为 model provider ----------
litellm_url = os.environ.get("LITELLM_BASE_URL")
if litellm_url:
    litellm_key = os.environ.get("LITELLM_API_KEY", "")
    default_model = os.environ.get("HERMES_DEFAULT_MODEL", "qwen-plus")
    # LiteLLM 是 OpenAI-compat, 需要 base_url 上追 /v1
    base = litellm_url.rstrip("/")
    if not base.endswith("/v1"):
        base = base + "/v1"

    model = data.setdefault("model", {})
    already = (
        model.get("provider") == "custom"
        and model.get("base_url") == base
        and model.get("api_key") == litellm_key
        and (model.get("default") == default_model or model.get("model") == default_model)
    )
    if not already:
        model["provider"] = "custom"
        model["base_url"] = base
        model["api_key"] = litellm_key
        # hermes 支持 "default" 或 "model" 两种 key 名, 都写以防
        model["default"] = default_model
        model["model"] = default_model
        dirty = True

if not dirty:
    sys.exit(0)

cfg_path.write_text(yaml.safe_dump(data, sort_keys=False))
tag = api_key[-6:] if api_key else "-"
print(f"[025-kiwiagent] config patched (api_server key tail=***{tag}, model={data.get('model',{}).get('default','?')})")
PY
